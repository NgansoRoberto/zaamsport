# --- Variables backend ---

# Connexion BD : en prod, utiliser DATABASE_URL (Neon/Supabase/Render Postgres).
# Format attendu : postgres://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# Alternative en dev : variables séparées (utilisées si DATABASE_URL est vide)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lamfunsport
DB_USER=postgres
DB_PASSWORD=kenko

# Secret JWT : DOIT être long et aléatoire en prod (Render peut le générer pour vous)
JWT_SECRET=

# Origines CORS autorisées (séparées par des virgules) ou "*" en dev
# ex : https://zaamsport.com,https://www.zaamsport.com
CORS_ORIGIN=*

# Préfixe d'URL (par défaut vide ; mettre /lamfunsport/api pour la compat Apache locale)
API_BASE_PATH=

# Activer 1 pour voir les erreurs PHP dans les réponses HTTP (NE PAS activer en prod)
APP_DEBUG=0

# --- Stockage des images uploadées ---
# local      = filesystem (dev uniquement, non persistant sur Render)
# cloudinary = Cloudinary (prod recommandé)
STORAGE_DRIVER=local

# Cloudinary (uniquement si STORAGE_DRIVER=cloudinary)
# Disponible sur : https://console.cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
